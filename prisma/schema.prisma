generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

// ─── Users ───────────────────────────────────────────────────────────────────

enum Role {
  ADMIN
  USER
}

model User {
  id           String     @id @default(auto()) @map("_id") @db.ObjectId
  email        String     @unique
  name         String
  passwordHash String
  role         Role       @default(USER)
  isActive     Boolean    @default(true)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  emailLogs    EmailLog[]

  @@map("users")
}

// ─── Email Logs ───────────────────────────────────────────────────────────────

enum EmailType {
  SINGLE
  BULK
}

enum EmailStatus {
  SUCCESS
  PARTIAL
  FAILED
}

model EmailLog {
  id          String      @id @default(auto()) @map("_id") @db.ObjectId
  userId      String      @db.ObjectId
  user        User        @relation(fields: [userId], references: [id])

  type        EmailType
  status      EmailStatus
  subject     String
  recipients  String[]    // list of email addresses
  totalSent   Int         @default(0)
  totalFailed Int         @default(0)
  errors      String[]    @default([])
  messageId   String?     // SES message ID (single emails)
  sentAt      DateTime    @default(now())

  @@map("email_logs")
}

// ─── Mail Provider Settings ────────────────────────────────────────────────

enum MailProvider {
  SES
  CPANEL
}

// Singleton document (one row) holding the active provider + credentials
// for every supported email backend. Only ADMIN users may read/write this
// via /api/settings. Whichever provider is `active` is used by
// src/lib/mailer.ts for every outgoing email.
model MailSettings {
  id     String       @id @default(auto()) @map("_id") @db.ObjectId
  active MailProvider @default(SES)

  // Shared "from" identity, used by whichever provider is active
  fromName  String @default("")
  fromEmail String @default("")

  // Amazon SES credentials
  sesRegion          String @default("us-east-1")
  sesAccessKeyId     String @default("")
  sesSecretAccessKey String @default("")

  // cPanel / generic SMTP credentials (works for any cPanel-hosted mailbox,
  // e.g. mail.yourdomain.com on port 465/587)
  smtpHost     String  @default("")
  smtpPort     Int     @default(465)
  smtpSecure   Boolean @default(true)
  smtpUsername String  @default("")
  smtpPassword String  @default("")

  updatedAt DateTime @updatedAt

  @@map("mail_settings")
}
